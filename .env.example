# AI Chat Assistant - Environment Variables Configuration

# Perplexity AI API Keys (add as many as needed for rotation)
PERPLEXITY_API_KEY1="pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
PERPLEXITY_API_KEY2="pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
PERPLEXITY_API_KEY3="pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
PERPLEXITY_API_KEY4="pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Google Gemini API Keys (add as many as needed for rotation)
GOOGLE_API_KEY1="AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GOOGLE_API_KEY2="AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GOOGLE_API_KEY3="AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GOOGLE_API_KEY4="AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Instructions:
# 1. Copy this file to .env in your project root
# 2. Replace the placeholder values with your actual API keys
# 3. You can have as many keys as needed (KEY1, KEY2, KEY3, etc.)
# 4. The system will automatically rotate through available keys
# 5. If a key fails due to rate limits, it will switch to the next one
# 6. Spark LLM is always available as a fallback

# API Key Sources:
# - Perplexity AI: https://www.perplexity.ai/settings/api
# - Google Gemini: https://makersuite.google.com/app/apikey

# Note: 
# - Remove any keys you don't have or don't want to use
# - The system will only use configured services that have valid keys
# - If no external API keys are configured, only Spark LLM will be used