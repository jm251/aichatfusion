# AI Chat Fusion - Environment Variables Example
# Copy this file to .env.local and configure your setup

# Backend Configuration (RECOMMENDED - More Secure)
# Set this to true to use the backend API for key management
VITE_USE_BACKEND=true
VITE_BACKEND_URL=http://localhost:3001

# SECURE PROXY MODE (MOST SECURE - Keys never leave server)
# Set this to true to route ALL AI API calls through the backend
# This means API keys are NEVER sent to the browser
# Requires backend to be running with proxy endpoints
VITE_USE_PROXY=true

# Direct Frontend Configuration (LESS SECURE - Keys exposed in build)
# Only use this for development or if you don't have a backend
# If VITE_USE_BACKEND is true, these are ignored
VITE_GROQ_API_KEY=
VITE_GOOGLE_API_KEY=
VITE_OPENAI_API_KEY=
VITE_OPENROUTER_API_KEY=
VITE_GITHUB_TOKEN=
VITE_COHERE_API_KEY=
VITE_XAI_API_KEY=

# Firebase Configuration (for chat history)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Multiple Keys Support (for rate limit handling)
# You can add numbered variants for any service:
# VITE_GROQ_API_KEY1=
# VITE_GROQ_API_KEY2=
# VITE_GOOGLE_API_KEY1=
# VITE_GOOGLE_API_KEY2=
# VITE_OPENAI_API_KEY1=
# VITE_OPENAI_API_KEY2=
# VITE_OPENROUTER_API_KEY1=
# VITE_OPENROUTER_API_KEY2=
# VITE_GITHUB_TOKEN1=
# VITE_GITHUB_TOKEN2=
# VITE_COHERE_API_KEY1=
# VITE_COHERE_API_KEY2=
# VITE_XAI_API_KEY1=
# VITE_XAI_API_KEY2=

